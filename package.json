{
	"name": "vivid-tab",
	"description": "\"VividTab: Your dynamic new tab for a brighter, more productive browsing experience.\"",
	"type": "module",
	"private": true,
	"packageManager": "bun@1.3.14",
	"engines": {
		"node": "24.18.0"
	},
	"scripts": {
		"postinstall": "bun run --cwd apps/vivid-tab postinstall",
		"prepare": "bunx --bun --no-install husky",
		"lint": "biome lint .",
		"format": "biome format --write .",
		"check": "biome check .",
		"check:fix": "biome check --write .",
		"lint-staged": "bunx --bun --no-install lint-staged"
	},
	"devDependencies": {
		"@biomejs/biome": "2.4.15",
		"@types/bun": "latest",
		"husky": "9.1.7",
		"lint-staged": "17.1.0"
	},
	"peerDependencies": {
		"typescript": "^7.0.2"
	},
	"workspaces": [
		"apps/*"
	]
}
