{
	"name": "@jrtilak/vivid-tab",
	"displayName": "Vivid Tab",
	"description": "A customizable new tab dashboard with bookmarks, search, widgets, themes, and wallpapers.",
	"version": "1.4.0",
	"author": "jrTilak <contact@jrtilak.dev>",
	"scripts": {
		"dev": "cross-env PLASMO_PUBLIC_BROWSER_NAME='chrome' plasmo dev",
		"dev:f": "cross-env PLASMO_PUBLIC_BROWSER_NAME='firefox' plasmo dev --target=firefox-mv3",
		"build": "cross-env PLASMO_PUBLIC_BROWSER_NAME='chrome' plasmo build",
		"build:f": "cross-env PLASMO_PUBLIC_BROWSER_NAME='firefox' plasmo build --target=firefox-mv3",
		"package": "bun run package:all",
		"package:all": "bun run package:c && bun run package:f",
		"package:c": "bun run build && cross-env PLASMO_PUBLIC_BROWSER_NAME='chrome' plasmo package --target=chrome-mv3",
		"package:f": "bun run build:f && cross-env PLASMO_PUBLIC_BROWSER_NAME='firefox' plasmo package --target=firefox-mv3",
		"release": "bun run package:all && bun run release:validate",
		"release:validate": "bun scripts/validate-release.ts",
		"check:dead-code": "knip",
		"test": "jest",
		"test:coverage": "jest --coverage",
		"test:e2e": "bun e2e/run.ts all",
		"test:e2e:c": "bun e2e/run.ts chromium",
		"test:e2e:ff": "bun e2e/run.ts firefox",
		"test:e2e:types": "tsc --noEmit --project e2e/tsconfig.json",
		"bangs:refresh": "bun scripts/refresh-bangs.ts",
		"quotes:refresh": "bun scripts/refresh-quotes.ts",
		"postinstall": "bun scripts/patch.ts",
		"build:css": "tailwindcss -i ./src/styles/index.css -o ./build/chrome-mv3-prod/minified.css --minify"
	},
	"dependencies": {
		"@dnd-kit/core": "^6.3.1",
		"@fontsource-variable/bricolage-grotesque": "^5.3.0",
		"@fontsource-variable/outfit": "^5.3.0",
		"@tabler/icons-react": "^3.45.0",
		"class-variance-authority": "^0.7.1",
		"clsx": "^2.1.1",
		"motion": "^12.42.2",
		"plasmo": "0.90.5",
		"radix-ui": "^1.6.4",
		"react": "19.2.7",
		"react-dom": "19.2.7",
		"tailwind-merge": "^3.6.0",
		"zod": "^4.4.3"
	},
	"devDependencies": {
		"@babel/core": "7.29.7",
		"@babel/preset-env": "7.29.7",
		"@babel/preset-react": "7.29.7",
		"@babel/preset-typescript": "7.29.7",
		"@jest/globals": "30.4.1",
		"@tailwindcss/postcss": "^4.3.3",
		"@testing-library/dom": "10.4.1",
		"@testing-library/react": "16.3.2",
		"@types/bun": "^1.3.14",
		"@types/chrome": "0.2.2",
		"@types/mocha": "^10.0.10",
		"@types/node": "24.13.3",
		"@types/react": "19.2.17",
		"@types/react-dom": "19.2.3",
		"@wdio/cli": "^9.29.1",
		"@wdio/globals": "^9.29.1",
		"@wdio/local-runner": "^9.29.1",
		"@wdio/mocha-framework": "^9.29.1",
		"@wdio/spec-reporter": "^9.29.1",
		"@wdio/types": "^9.29.1",
		"babel-jest": "^30.4.1",
		"cross-env": "^10.1.0",
		"fake-indexeddb": "6.2.5",
		"jest": "^30.4.2",
		"jest-environment-jsdom": "30.4.1",
		"knip": "^6.27.0",
		"postcss": "^8.5.20",
		"shadcn": "^4.13.1",
		"tailwindcss": "^4.3.3",
		"tw-animate-css": "^1.4.0",
		"typescript": "7.0.2",
		"webdriverio": "^9.29.1"
	},
	"manifest": {
		"commands": {
			"toggle-vivid-search": {
				"suggested_key": {
					"default": "Ctrl+Shift+Space",
					"mac": "Command+Shift+Space"
				},
				"description": "Toggle Vivid Tab search"
			}
		},
		"host_permissions": [
			"https://suggestqueries.google.com/*",
			"https://ipapi.co/*",
			"https://api.weatherapi.com/*",
			"https://cdn.weatherapi.com/*",
			"https://wallhaven.cc/*",
			"https://w.wallhaven.cc/*",
			"https://th.wallhaven.cc/*"
		],
		"overrides": {
			"firefox": {
				"host_permissions": [
					"https://ipapi.co/*",
					"https://api.weatherapi.com/*",
					"https://cdn.weatherapi.com/*",
					"https://wallhaven.cc/*",
					"https://w.wallhaven.cc/*",
					"https://th.wallhaven.cc/*"
				],
				"permissions": [
					"bookmarks",
					"storage",
					"unlimitedStorage",
					"search",
					"topSites",
					"geolocation",
					"alarms"
				]
			}
		},
		"permissions": [
			"bookmarks",
			"storage",
			"unlimitedStorage",
			"search",
			"topSites",
			"geolocation",
			"alarms",
			"favicon"
		],
		"optional_permissions": [
			"history"
		],
		"browser_specific_settings": {
			"gecko": {
				"id": "vividtab@jrtilak.dev",
				"strict_min_version": "140.0",
				"data_collection_permissions": {
					"required": [
						"locationInfo",
						"searchTerms"
					]
				}
			}
		}
	}
}
