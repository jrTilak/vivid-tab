---
import { Icon } from "astro-icon/components";
import { FEATURES } from "../../data/site";
---

<section class="site-container flex flex-col gap-16 px-8">
	<div class="flex flex-col items-center justify-center" id="features">
		<h2 class="w-full max-w-md text-center text-3xl font-bold text-foreground md:text-4xl lg:text-5xl">
			Product Features
		</h2>
		<p class="mt-4 max-w-xl text-center text-muted-foreground">
			A customizable, feature-rich new tab with shortcuts, search, widgets, and productivity
			tools—free and open source.
		</p>
	</div>

	<div class="grid grid-cols-1 gap-12 md:grid-cols-2 xl:grid-cols-3">
		{
			FEATURES.map((feature) => (
				<article class="feature-card relative border border-dashed border-border p-6 transition-shadow hover:shadow-2xl">
					<Icon
						aria-hidden="true"
						class="-left-3 -top-3 absolute size-6 bg-background text-primary"
						name="tabler:plus"
					/>
					<Icon
						aria-hidden="true"
						class="-right-3 -top-3 absolute size-6 bg-background text-foreground"
						name="tabler:plus"
					/>
					<Icon
						aria-hidden="true"
						class="-bottom-3 -left-3 absolute size-6 bg-background text-foreground"
						name="tabler:plus"
					/>
					<Icon
						aria-hidden="true"
						class="-bottom-3 -right-3 absolute size-6 bg-background text-primary"
						name="tabler:plus"
					/>

					<span
						class="mb-4 inline-flex size-10 items-center justify-center rounded-md border border-border bg-background text-foreground shadow-sm"
					>
						<Icon class="size-5" name={feature.icon} />
					</span>
					<h3 class="mb-2 text-xl font-bold text-foreground">{feature.title}</h3>
					<p class="leading-7 text-muted-foreground">{feature.description}</p>
				</article>
			))
		}
	</div>
</section>
