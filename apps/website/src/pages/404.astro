---
import BaseLayout from "../layouts/BaseLayout.astro";
---

<BaseLayout description="The requested Vivid Tab page was not found." title="Page not found | Vivid Tab">
	<main class="flex min-h-[60vh] flex-col items-center justify-center p-4 text-center">
		<h1 class="text-5xl font-bold">404</h1>
		<p class="mt-4 text-muted-foreground">The page you requested does not exist.</p>
		<a class="button button-primary mt-8" href="/">Return home</a>
	</main>
</BaseLayout>
